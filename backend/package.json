{
  "name": "agile-cards-board-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend for the agile-cards dashboard. Express + TypeScript + better-sqlite3 + chokidar + SSE.",
  "license": "SEE LICENSE IN ../LICENSE",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/routes/stories.test.ts src/cost/rates.test.ts src/db/ranks.test.ts",
    "create-token": "tsx scripts/create-token.ts",
    "list-tokens": "tsx scripts/list-tokens.ts",
    "revoke-token": "tsx scripts/revoke-token.ts",
    "seed": "tsx scripts/seed-cards.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.16.10",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
