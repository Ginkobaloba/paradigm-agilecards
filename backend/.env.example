# Paradigm AgileCards backend -- example environment (AC-CARDS-008)
#
# This file documents the configuration the backend reads. It contains
# PLACEHOLDERS ONLY -- no real secrets. Copy to `.env` for local dev (gitignored)
# or, in staging/production, let Infisical inject these at boot.
#
# Gitleaks scans this repo; never put real client secrets or tokens here.

# --- Secret source selection -------------------------------------------------
# "env"       -> read the values below from the environment (local/CI default).
# "infisical" -> fetch secrets from Infisical at boot via a machine identity.
PARADIGM_SECRETS_PROVIDER=env

# --- JWT verification (public, non-secret config) ----------------------------
# Defaults already point at the Paradigm IdP; override only for other envs.
PARADIGM_JWT_ISSUER=https://auth.paradigm.codes
PARADIGM_JWT_AUDIENCE=paradigm-agilecards
# Optional: derived from the issuer when unset.
# PARADIGM_JWKS_URL=https://auth.paradigm.codes/.well-known/jwks.json

# --- Infisical machine identity (only when PARADIGM_SECRETS_PROVIDER=infisical)
# These are injected by the runtime environment, NOT committed. Placeholders:
# INFISICAL_API_URL=https://app.infisical.com
# INFISICAL_CLIENT_ID=<machine-identity-client-id>
# INFISICAL_CLIENT_SECRET=<machine-identity-client-secret>
# INFISICAL_PROJECT_ID=<infisical-project-id>
# INFISICAL_ENVIRONMENT=prod
# INFISICAL_SECRET_PATH=/agilecards
