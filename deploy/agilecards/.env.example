# AgileCards deploy configuration -- PLACEHOLDERS ONLY, no real secrets.
# Copy to .env (gitignored) next to docker-compose.yml and fill in values.
# Gitleaks scans this repo; never commit a populated .env.

# --- Postgres credentials ----------------------------------------------------
# Superuser/owner password. Used by the postgres container itself and by the
# one-shot migrate service (Alembic needs owner privileges for roles/RLS/DDL).
POSTGRES_PASSWORD=<generate-a-long-random-password>

# Password for the agilecards_app runtime role (NOSUPERUSER, NOBYPASSRLS --
# the role RLS actually applies to). Distinct from POSTGRES_PASSWORD on
# purpose: the API must never hold owner credentials.
POSTGRES_APP_PASSWORD=<generate-a-different-long-random-password>

# --- JWT verification (public, non-secret config) ----------------------------
# Defaults already point at the production Paradigm IdP; uncomment to override.
# PARADIGM_JWT_ISSUER=https://auth.paradigm.codes
# PARADIGM_JWT_AUDIENCE=paradigm-agilecards

# JWKS endpoint. Leave unset in production (derived from the issuer).
# DEV PROFILE ONLY: point it at the compose-internal dev JWKS server and mint
# tokens with backend/scripts/mint_dev_token.py. Never set this on a
# production host.
# PARADIGM_JWKS_URL=http://dev-idp/.well-known/jwks.json

# --- Optional knobs -----------------------------------------------------------
# Host port for the web (Caddy) service. Default 8080.
# WEB_PORT=8080

# Where the frontend is mounted in URL space ("/board/" behind the portal).
# VITE_BASE_PATH=/

# Extra CORS origins (comma-separated). Same-origin deploys need none.
# PARADIGM_CORS_ORIGINS=

# Secrets provider for the API: "env" (default) or "infisical".
# When "infisical", also provide the INFISICAL_* machine-identity vars
# (see backend/.env.example) via the runtime environment.
# PARADIGM_SECRETS_PROVIDER=env
