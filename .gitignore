# OS
Thumbs.db
.DS_Store
desktop.ini

# Secrets. A real API key in a committed .env file is a credential
# leak. Both the engine and the board read secrets straight from the
# process environment, never from a .env file, but ignore the pattern
# anyway so a stray local override does not land in a commit.
.env
.env.*
*.local.env
# ...but the placeholder template (no real secrets) must be tracked.
!.env.example

# Editors
.vscode/
.idea/
*.swp
*~

# Sync-tool detritus
.synctest.*
*.tmp
*.bak

# Logs and test outputs
*.log
logs/
tests/cards-rename-test/

# Build artifacts (both ecosystems)
dist/
build/
*.tsbuildinfo
coverage/

# Python / node detritus (covers both apps recursively)
__pycache__/
*.pyc
.venv/
node_modules/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Engine card store files. The runner's SQLite store (and Dolt's storage
# dir) live outside the repo by design; never commit one if it lands
# inside the tree during local runs.
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal

# Engine runtime data lives outside this repo by design.
# If you ever symlink the runtime dir in here for convenience, ignore it.
todo/
_batches/

# Scratch outputs from agents and local runs. Both apps have an
# outputs/ folder for human-readable scratch artifacts that should
# not live in version control.
outputs/

# Board backend SQLite runtime state (the board's local DB lives at
# apps/board/backend/data/ by default; pinned here so an accidental
# in-repo DB does not get committed).
apps/board/backend/data/

##########################
# Probe / Claude / Python build artifacts (added 2026-05-29 per retro auto-actionable batch)
##########################
.claude/
**/*.egg-info/
.tmp_*
.size_test
.write_test
