# Copy this file to .env and fill in real values. .env is gitignored.
#
# Cloudflare Tunnel connector token for the agile-cards-board-tunnel.
# Required only on the machine that runs the cloudflared service.
#
# How to get a fresh one:
#   1. Cloudflare dash -> Zero Trust -> Networks -> Tunnels
#      -> agile-cards-board-tunnel -> "Configure" -> reveal token.
#   2. Or via API (account-scoped token with Cloudflare Tunnel:Read):
#      GET /accounts/{account_id}/cfd_tunnel/{tunnel_id}/token
#
# Tunnel name: agile-cards-board-tunnel
# Tunnel ID:   <YOUR_TUNNEL_ID>   (find in Zero Trust -> Networks -> Tunnels)
# Account ID:  <YOUR_ACCOUNT_ID>  (find in the Cloudflare dashboard URL or account home)
#
# Treat this token like a credential. It grants the holder the ability
# to register a connector for this tunnel and serve traffic for the
# tunnel's configured hostnames.
TUNNEL_TOKEN=replace-with-tunnel-token
